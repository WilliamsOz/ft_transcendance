model Mutes {
  id Int @id @default(autoincrement())
  channel_id Int
  user_id Int
  unmutetime DateTime
  user_1    Discussion[] @relation(name: "user_1") // relation user_id_1 a sender_id(game_invitation)

}
generator client {
  provider = "prisma-client-js"
}